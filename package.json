{
  "name": "valdyum-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @valdyum/client --filter @valdyum/server dev",
    "dev:client": "pnpm --filter @valdyum/client dev",
    "dev:server": "pnpm --filter @valdyum/server dev",
    "build": "pnpm --parallel --filter @valdyum/client --filter @valdyum/server build",
    "lint": "pnpm -r lint",
    "workers": "pnpm --filter @valdyum/server workers",
    "cli": "pnpm --filter @valdyum/server cli",
    "valdyum": "pnpm --filter @valdyum/server cli"
  }
}
